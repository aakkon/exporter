# === Required ===
SQS_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>.fifo
EXPORT_S3_BUCKET=your-export-data-bucket
MANIFEST_S3_BUCKET=your-manifest-bucket-name
INFLUXDB_SECRET_NAME=your/secretsmanager/path/to/influxdb

# === Optional (have defaults) ===
# AWS_REGION=your_region
# EXPORT_S3_PREFIX=exports/
# MANIFEST_S3_KEY=Manifest_SQS_Processed.json
# LOG_LEVEL=INFO
